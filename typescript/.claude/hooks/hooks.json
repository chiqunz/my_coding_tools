{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-sensitive-reads.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Write",
          "file_paths": ["**.ts", "**.tsx"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "pnpm biome check --apply \"$CLAUDE_FILE_PATH\"",
            "timeout": 30000,
            "on_failure": "continue"
          }
        ]
      }
    ],
    "PreCommit": [
      {
        "matcher": {},
        "hooks": [
          {
            "type": "command",
            "command": "pnpm tsc --noEmit && pnpm vitest run --reporter=dot",
            "timeout": 120000,
            "on_failure": "stop"
          }
        ]
      }
    ]
  }
}
