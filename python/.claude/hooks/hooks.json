{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-sensitive-reads.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Write",
          "file_paths": ["**.py"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check --fix \"$CLAUDE_FILE_PATH\" && uv run ruff format \"$CLAUDE_FILE_PATH\"",
            "timeout": 30000,
            "on_failure": "continue"
          }
        ]
      }
    ],
    "PreCommit": [
      {
        "matcher": {},
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check src/ && uv run mypy src/ --no-error-summary && uv run pytest tests/ -x -q --tb=short",
            "timeout": 120000,
            "on_failure": "stop"
          }
        ]
      }
    ]
  }
}
